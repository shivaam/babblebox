{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config ./vite/common.config.js --debug",
    "build": "tsc && vite build --config ./vite/common.config.js --debug",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "tailwindcss-build": "npx tailwindcss -c ./vite/tailwind.config.js  -i ./babblebox/static/vite_assets/css/project.css -o ./babblebox/static/vite_assets/css/tail.css --verbose"
  },
  "dependencies": {
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.2",
    "@mui/material": "^5.15.2",
    "@mui/system": "^5.15.2",
    "@popperjs/core": "^2.11.8",
    "axios": "1.6.7",
    "bootstrap": "^5.3.2",
    "date-fns": "^2.28.0",
    "fix-webm-duration": "^1.0.5",
    "flowbite": "^2.3.0",
    "react": "18.3.*",
    "react-audio-voice-recorder": "^2.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "6.23.0",
    "sass": "^1.70.0",
    "tailwindcss": "^3.4.3",
    "esbuild": "^0.19.12",
    "autoprefixer": "^10.4.19"
  },
  "devDependencies": {
    "@fontsource/roboto": "^5.0.12",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^18.19.10",
    "@types/react": "18.3.*",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.12",
    "web-vitals": "^2.1.4"
  },
  "overrides": {
    "react": "18.3.*"
  }
