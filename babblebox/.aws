aws ecr create-repository --repository-name babblebox_production_django
aws ecr create-repository --repository-name babblebox_production_traefik

docker push 891376962618.dkr.ecr.us-east-1.amazonaws.com/babblebox_production_django
docker push 891376962618.dkr.ecr.us-east-1.amazonaws.com/babblebox_production_traefik


aws ecr describe-repositories --repository-names babblebox_production_django --query 'repositories[0].repositoryUri'


persistent://babblebox/audio_processing/new_message

kubectl exec -n pulsar  pulsar-broker-0 -- bin/pulsar-admin tenants create babblebox
kubectl exec -n pulsar  pulsar-broker-0 -- bin/pulsar-admin namespaces create babblebox/audio_processing
kubectl exec -n pulsar  pulsar-broker-0 -- bin/pulsar-admin topics create persistent://babblebox/audio_processing/new_message
